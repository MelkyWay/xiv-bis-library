{
  "name": "xiv-bis-library",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:categories": "node scripts/tools/generate-categories.mjs",
    "generate:roles": "node scripts/tools/generate-roles.mjs",
    "generate:jobs": "node scripts/tools/generate-jobs.mjs",
    "generate:encounters": "node scripts/tools/generate-encounters.mjs",
    "generate:issue-templates": "node scripts/tools/generate-issue-templates.mjs",
    "generate:config": "npm run generate:categories && npm run generate:roles && npm run generate:jobs && npm run generate:encounters",
    "dev": "npm run generate:config && vite",
    "build": "npm run generate:config && vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "npm run generate:config && vitest run",
    "test:watch": "npm run generate:config && vitest",
    "test:coverage": "npm run generate:config && vitest run --coverage",
    "lint": "npm run generate:config && eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "import:gear": "node scripts/tools/import-gearsets.mjs",
    "build:xivgear-set": "node scripts/tools/build-xivgear-set-json.mjs"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.10"
  }
}
